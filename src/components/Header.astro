---
import Mark from './Mark.astro'

const NAV_LINKS = [
  { label: 'HOME', href: '/' },
  { label: 'NOTES', href: '/notes' },
  { label: 'CONTACT', href: '/contact' },
]

// build format 'file' yields pathnames like /notes.html — normalize before matching
const path = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '/') || '/'
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/')
---

<header id="site-header">
  <nav class="topnav" aria-label="Site">
    <a href="/" class="logo"><span class="logo-mark" aria-hidden="true"><Mark size={20} /></span> <span>REMOTELY HUMAN</span></a>
    <div class="nav-right">
      <ul class="desktop-menu">
        {NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class={isActive(link.href) ? 'active' : ''} aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a>
          </li>
        ))}
      </ul>
      <button id="theme-toggle" class="icon-btn" aria-label="Switch to light theme" aria-pressed="false">
        <svg class="icon-sun" aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4.5"/><line x1="12" y1="2" x2="12" y2="4.5"/><line x1="12" y1="19.5" x2="12" y2="22"/><line x1="2" y1="12" x2="4.5" y2="12"/><line x1="19.5" y1="12" x2="22" y2="12"/><line x1="4.8" y1="4.8" x2="6.6" y2="6.6"/><line x1="17.4" y1="17.4" x2="19.2" y2="19.2"/><line x1="4.8" y1="19.2" x2="6.6" y2="17.4"/><line x1="17.4" y1="6.6" x2="19.2" y2="4.8"/></svg>
        <svg class="icon-moon" aria-hidden="true" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>
      <button id="menu-open" class="icon-btn menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-overlay">
        <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
      </button>
    </div>
  </nav>
  <div id="mobile-overlay" class="mobile-overlay" role="dialog" aria-modal="true" aria-label="Navigation menu" aria-hidden="true">
    <div class="mobile-top">
      <a href="/" class="logo"><span class="logo-mark" aria-hidden="true"><Mark size={20} /></span> <span>REMOTELY HUMAN</span></a>
      <button id="menu-close" class="icon-btn" aria-label="Close menu">
        <svg aria-hidden="true" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
      </button>
    </div>
    <ul>
      {NAV_LINKS.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
    </ul>
  </div>
</header>

<script>
  // ————— theme toggle —————
  const root = document.documentElement
  const toggle = document.getElementById('theme-toggle')
  const syncToggle = () => {
    const light = root.getAttribute('data-theme') === 'light'
    toggle?.setAttribute('aria-pressed', String(light))
    toggle?.setAttribute('aria-label', light ? 'Switch to dark theme' : 'Switch to light theme')
  }
  syncToggle()
  toggle?.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
    root.setAttribute('data-theme', next)
    localStorage.setItem('rh-theme', next)
    syncToggle()
  })

  // ————— nav background on scroll (write only on state flip) —————
  const hdr = document.getElementById('site-header')
  let scrolled = false
  const onScroll = () => {
    const now = window.scrollY > 40
    if (now !== scrolled) {
      scrolled = now
      hdr?.classList.toggle('scrolled', now)
    }
  }
  onScroll()
  window.addEventListener('scroll', onScroll, { passive: true })

  // ————— mobile menu: focus-managed dialog —————
  const overlay = document.getElementById('mobile-overlay')
  const openBtn = document.getElementById('menu-open')
  const closeBtn = document.getElementById('menu-close')

  const focusables = () =>
    Array.from(overlay?.querySelectorAll<HTMLElement>('a, button') ?? [])

  const setOpen = (open: boolean) => {
    overlay?.classList.toggle('open', open)
    overlay?.setAttribute('aria-hidden', String(!open))
    openBtn?.setAttribute('aria-expanded', String(open))
    if (open) {
      closeBtn?.focus()
    } else {
      openBtn?.focus()
    }
  }

  openBtn?.addEventListener('click', () => setOpen(true))
  closeBtn?.addEventListener('click', () => setOpen(false))
  overlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)))

  document.addEventListener('keydown', (e) => {
    if (!overlay?.classList.contains('open')) return
    if (e.key === 'Escape') {
      setOpen(false)
      return
    }
    if (e.key === 'Tab') {
      const els = focusables()
      if (els.length === 0) return
      const first = els[0]
      const last = els[els.length - 1]
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault()
        last.focus()
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault()
        first.focus()
      }
    }
  })
</script>

<style>
  header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 40;
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  header.scrolled {
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom-color: var(--hairline);
  }
  .topnav {
    max-width: 87.5rem;
    margin: 0 auto;
    height: 4.5rem;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    color: var(--ink);
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.2em;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }
  .logo:hover {
    color: var(--ink);
    opacity: 1;
  }
  .logo-mark {
    display: flex;
    color: var(--accent);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .desktop-menu {
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }
  .desktop-menu a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    position: relative;
    transition: color 0.3s ease;
  }
  .desktop-menu a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 1px;
    width: 0;
    background: var(--ink);
    transition: width 0.3s ease;
  }
  .desktop-menu a:hover {
    color: var(--ink);
  }
  .desktop-menu a:hover::after {
    width: 100%;
  }
  .desktop-menu a.active {
    color: var(--accent-text);
  }
  .desktop-menu a.active::after {
    width: 100%;
    background: var(--accent);
  }
  .icon-btn {
    background: none;
    border: none;
    color: var(--dim);
    cursor: pointer;
    display: flex;
    padding: 0.3rem;
    transition: color 0.3s ease;
  }
  .icon-btn:hover {
    color: var(--ink);
  }
  :global([data-theme='dark']) .icon-moon {
    display: none;
  }
  :global([data-theme='light']) .icon-sun {
    display: none;
  }
  .menu-btn {
    display: flex;
  }
  @media (min-width: 768px) {
    .desktop-menu {
      display: flex;
    }
    .menu-btn {
      display: none;
    }
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.4s ease, visibility 0s linear 0.4s;
  }
  .mobile-overlay.open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition: opacity 0.4s ease;
  }
  .mobile-top {
    height: 4.5rem;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mobile-overlay ul {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.2rem;
  }
  .mobile-overlay ul a {
    font-family: var(--font-display);
    font-size: 2.6rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .mobile-overlay ul a:hover {
    color: var(--accent-text);
  }
</style>
