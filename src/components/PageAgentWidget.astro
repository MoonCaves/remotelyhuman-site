{/*
  On-page assistant mount point. The engine and the face are decoupled
  (2026-07-15, mirrored from paymentverse-site): this component just wires a
  headless engine to a swappable face and mounts it off the critical path.

  - Engine:  src/agent/engine.ts  (headless PageAgentCore — LLM proxy, prompts,
             session memory, telemetry, tools). Backend unchanged.
  - Face:    src/agent/faces/*    (the visual layer). Swap FACE below — Rive
             bot, text-bubble, stock panel — without touching the engine.
  See AGENTS.md for the architecture and the DOM-friendliness rules a face
  must honour. Never ship the vendor's jsDelivr demo bundle — it routes page
  data through Alibaba's hosted test LLM.
*/}
<script>
  import { createEngine } from '../agent/engine'
  // The one swap point. Point this at a different face module to change the
  // assistant's whole look/UX; the engine is untouched.
  import { minimalFace as FACE } from '../agent/faces/minimal'

  const start = () => {
    if ((window as any).__rhFaceMounted) return
    ;(window as any).__rhFaceMounted = true
    const engine = createEngine()
    FACE.mount(engine)
  }

  // Off the critical path: load after first idle.
  if ('requestIdleCallback' in window) {
    requestIdleCallback(() => start(), { timeout: 8000 })
  } else {
    setTimeout(start, 3000)
  }
</script>

