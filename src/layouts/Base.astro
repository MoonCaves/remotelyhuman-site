---
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  description?: string
}
const { title, description = 'The official home of Remotely Human. We work quietly across many projects.' } = Astro.props

const canonical = new URL(Astro.url.pathname, Astro.site)
const ogImage = new URL('/og.png', Astro.site)

const jsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Remotely Human LLC',
    url: 'https://remotelyhuman.com',
    logo: 'https://remotelyhuman.com/brand/rh-mark-padded.svg',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Remotely Human',
    url: 'https://remotelyhuman.com',
  },
])
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#09070d" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#f7f5fb" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Remotely Human" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/brand/rh-mark-padded.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="alternate" type="application/rss+xml" title="Remotely Human — Notes" href="/rss.xml" />
    <script type="application/ld+json" set:html={jsonLd} />
    <script is:inline>
      // Theme before first paint: stored choice wins, otherwise dark (brand default)
      ;(function () {
        var t = localStorage.getItem('rh-theme')
        document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark')
      })()
    </script>
    <script
      defer
      src="https://analytics.remotelyhuman.com/script.js"
      data-website-id="648fbd82-b3b1-4260-b235-318aae60eff2"
      data-domains="remotelyhuman.com,www.remotelyhuman.com"
    ></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root,
  :root[data-theme='dark'] {
    color-scheme: dark;
    --bg: #09070d;
    --panel: #120e1a;
    --ink: #f1eef7;
    --dim: rgba(241, 238, 247, 0.68);
    --faint: rgba(241, 238, 247, 0.55);
    --accent: #8b5cf6;
    --accent-hover: #a78bfa;
    --accent-text: #a78bfa;
    --accent-contrast: #ffffff;
    --hairline: rgba(241, 238, 247, 0.12);
    --graph-node: 167, 139, 250;
    --graph-link: 241, 238, 247;
    --font-display: 'Inter', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, monospace;
    /* type scale: body copy resolves to these three, mono labels to the pairs below.
       Deliberate exceptions: hero tagline (12px/0.25em focal accent), chip-note
       ("// comment" style, untracked like code), footer nav (lowercase 12px). */
    --text-sm: 14px;
    --text-md: 15px;
    --label-sm: 10px;
    --label-md: 11px;
    --track-tight: 0.2em;
    --track-wide: 0.3em;
  }

  :root[data-theme='light'] {
    color-scheme: light;
    --bg: #f7f5fb;
    --panel: #ffffff;
    --ink: #191426;
    --dim: rgba(25, 20, 38, 0.68);
    --faint: rgba(25, 20, 38, 0.6);
    --accent: #6d28d9;
    --accent-hover: #8b5cf6;
    --accent-text: #6d28d9;
    --accent-contrast: #ffffff;
    --hairline: rgba(25, 20, 38, 0.13);
    --graph-node: 109, 40, 217;
    --graph-link: 25, 20, 38;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    min-height: 100dvh;
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  ::selection {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  a {
    color: var(--accent-text);
    text-decoration: none;
  }
  a:hover {
    color: var(--accent-hover);
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }

  .skip-link {
    position: fixed;
    top: 0.75rem;
    left: 0.75rem;
    z-index: 100;
    padding: 0.6rem 1.1rem;
    background: var(--panel);
    color: var(--ink);
    border: 1px solid var(--accent);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    transform: translateY(-200%);
  }
  .skip-link:focus {
    transform: translateY(0);
  }
</style>
