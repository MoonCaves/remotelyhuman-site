---
interface Props {
  title: string
  description?: string
}
const { title, description = 'The official home of Remotely Human. We work quietly across many projects.' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;800&family=Inter:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #14151a;
    --panel: #1a1b21;
    --ink: #f1f0f7;
    --dim: rgba(241, 240, 247, 0.64);
    --faint: rgba(241, 240, 247, 0.4);
    --accent: #ed336b;
    --accent-hover: #fa487e;
    --hairline: rgba(255, 255, 255, 0.11);
    --font-display: 'Sora', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, monospace;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    color-scheme: dark;
  }

  body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }

  ::selection {
    background: var(--accent);
    color: #fff;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }
  a:hover {
    color: var(--accent-hover);
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
