---
interface Props {
  title: string
  description?: string
}
const { title, description = 'The official home of Remotely Human. We work quietly across many projects.' } = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/brand/rh-mark-padded.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <script is:inline>
      // Theme before first paint: stored choice wins, otherwise dark (brand default)
      ;(function () {
        var t = localStorage.getItem('rh-theme')
        document.documentElement.setAttribute('data-theme', t === 'light' ? 'light' : 'dark')
      })()
    </script>
    <script
      defer
      src="https://analytics.remotelyhuman.com/script.js"
      data-website-id="648fbd82-b3b1-4260-b235-318aae60eff2"
      data-domains="remotelyhuman.com,www.remotelyhuman.com"
    ></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&family=Plus+Jakarta+Sans:wght@600;700;800&family=Instrument+Serif:ital@0;1&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root,
  :root[data-theme='dark'] {
    color-scheme: dark;
    --bg: #09070d;
    --panel: #120e1a;
    --ink: #f1eef7;
    --dim: rgba(241, 238, 247, 0.68);
    --faint: rgba(241, 238, 247, 0.42);
    --accent: #8b5cf6;
    --accent-hover: #a78bfa;
    --accent-text: #a78bfa;
    --accent-contrast: #ffffff;
    --hairline: rgba(241, 238, 247, 0.12);
    --graph-node: 167, 139, 250;
    --graph-link: 241, 238, 247;
    --font-display: 'Inter', system-ui, sans-serif;
    --font-body: 'Inter', system-ui, sans-serif;
    --font-jakarta: 'Plus Jakarta Sans', system-ui, sans-serif;
    --font-serif: 'Instrument Serif', Georgia, serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, monospace;
  }

  :root[data-theme='light'] {
    color-scheme: light;
    --bg: #f7f5fb;
    --panel: #ffffff;
    --ink: #191426;
    --dim: rgba(25, 20, 38, 0.68);
    --faint: rgba(25, 20, 38, 0.45);
    --accent: #6d28d9;
    --accent-hover: #8b5cf6;
    --accent-text: #6d28d9;
    --accent-contrast: #ffffff;
    --hairline: rgba(25, 20, 38, 0.13);
    --graph-node: 109, 40, 217;
    --graph-link: 25, 20, 38;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
  }

  body {
    font-family: var(--font-body);
    font-size: 16px;
    line-height: 1.7;
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
    transition: background-color 0.4s ease, color 0.4s ease;
  }

  ::selection {
    background: var(--accent);
    color: var(--accent-contrast);
  }

  a {
    color: var(--accent-text);
    text-decoration: none;
  }
  a:hover {
    color: var(--accent-hover);
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
