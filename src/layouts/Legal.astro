---
import Base from './Base.astro'
import Footer from '../components/Footer.astro'

interface Props {
  title: string
  heading: string
}
const { title, heading } = Astro.props
---

<Base title={title}>
  <main>
    <a class="back" href="/">← Back to site</a>
    <h1>{heading}</h1>
    <p class="dates">
      Effective Date: June 02, 2025<br />
      Last Updated: June 02, 2025
    </p>
    <article>
      <slot />
    </article>
  </main>
  <Footer />
</Base>

<style is:global>
  main {
    max-width: 42rem;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }
  .back {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--dim);
  }
  .back:hover {
    color: var(--ink);
  }
  main h1 {
    margin-top: 1.5rem;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.6rem, 5vw, 2.1rem);
    letter-spacing: -0.02em;
  }
  .dates {
    margin-top: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--faint);
  }
  article {
    margin-top: 2.5rem;
    font-size: 0.95rem;
    color: var(--dim);
  }
  article h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--ink);
    margin: 2.25rem 0 0.6rem;
    padding-top: 2.25rem;
    border-top: 1px solid var(--hairline);
  }
  article h2 span {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.8rem;
    color: var(--accent-text);
    margin-right: 0.6rem;
  }
  article ul {
    margin: 0.5rem 0 0.75rem;
    padding-left: 1.25rem;
  }
  article li {
    margin-bottom: 0.25rem;
  }
  article p {
    margin-bottom: 0.75rem;
  }
  article strong {
    color: var(--ink);
    font-weight: 500;
  }
  .contact-block {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 2;
  }
</style>
