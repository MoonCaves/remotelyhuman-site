---
import Base from '../layouts/Base.astro'
import Mark from '../components/Mark.astro'
---

<Base title="404 — Remotely Human">
  <main id="main">
    <span class="brain" aria-hidden="true"><Mark size={40} /></span>
    <h1>404</h1>
    <p>This page doesn’t exist. It may be dreaming.</p>
    <a href="/">← Back to site</a>
  </main>
</Base>

<style>
  main {
    min-height: calc(100vh - 7rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    gap: 0.75rem;
  }
  .brain {
    color: var(--faint);
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 2.5rem;
    letter-spacing: -0.03em;
  }
  p {
    color: var(--dim);
  }
  a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--dim);
  }
  a:hover {
    color: var(--ink);
  }
</style>
