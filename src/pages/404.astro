---
import Base from '../layouts/Base.astro'
import Footer from '../components/Footer.astro'
---

<Base title="404 — Remotely Human">
  <main>
    <span class="brain" aria-hidden="true">🧠</span>
    <h1>404</h1>
    <p>This page doesn’t exist. It may be dreaming.</p>
    <a href="/">← Back to site</a>
  </main>
  <Footer />
</Base>

<style>
  main {
    min-height: calc(100vh - 7rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    gap: 0.75rem;
  }
  .brain {
    font-size: 2.5rem;
    opacity: 0.5;
    filter: grayscale(1);
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2.5rem;
  }
  p {
    color: var(--dim);
  }
  a {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--dim);
  }
  a:hover {
    color: var(--ink);
  }
</style>
