---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'

const notes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
---

<Base title="Remotely Human">
  <script is:inline>
    // Legacy Carrd hash-section URLs → real pages (OAuth verification links, old bookmarks)
    const map = {
      '#privacy-policy-section': '/privacy',
      '#privacy-policy': '/privacy',
      '#privacy': '/privacy',
      '#terms-of-service-section': '/terms',
      '#terms-of-service': '/terms',
      '#terms': '/terms',
    }
    const target = map[location.hash.toLowerCase()]
    if (target) location.replace(target)
  </script>

  <!-- Memory-graph constellation background -->
  <canvas id="graph-canvas" aria-hidden="true"></canvas>
  <div id="cursor-glow" aria-hidden="true"></div>

  <main id="main">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-inner">
        <p class="eyebrow">The Official Home of Remotely Human</p>

        <p class="tagline-slot"><span id="hero-tagline">Don&rsquo;t give up on your dreams</span></p>

        <h1 class="name">
          <span class="name-line">Remotely</span>
          <span class="name-line name-grad">Human</span>
        </h1>

        <p class="description">
          We work quietly across many projects. If you received an email from
          @remotelyhuman.com, you&rsquo;re in the right place.
        </p>

        <div class="chips">
          <a href="/notes" class="chip chip-a">
            <span class="dot"></span>
            <span class="chip-label">Notes</span>
            <span class="chip-note">// the garden</span>
          </a>
          <span class="amp" aria-hidden="true">&amp;</span>
          <a href="/contact" class="chip chip-b">
            <span class="dot"></span>
            <span class="chip-label">Contact Ops</span>
            <span class="chip-note">// replies: eventual</span>
          </a>
        </div>
      </div>

      <div class="scroll-hint" aria-hidden="true">
        <span>Scroll</span>
        <div class="scroll-track"><div class="scroll-thumb"></div></div>
      </div>
    </section>

    <!-- What we do -->
    <section class="band">
      <div class="band-inner">
        <div class="band-head reveal-up">
          <span class="kicker">What We Do</span>
          <h2><span class="uword u1">Notes</span> &amp; <span class="uword u2">ops</span></h2>
        </div>
        <div class="cards">
          <a href="/notes" class="card reveal-up">
            <span class="card-kicker">Writing</span>
            <h3>The garden</h3>
            <p>
              A garden, not a blog. Notes land here when a conversation or a build
              produces something worth keeping — no theme, no schedule.
            </p>
            <span class="card-cta"><span class="card-rule"></span>Read Notes</span>
          </a>
          <a href="/contact" class="card reveal-up">
            <span class="card-kicker">Operations</span>
            <h3>The ops desk</h3>
            <p>
              Status: dreaming. Keep sleeping. The desk reads everything that
              comes through — say hello and we&rsquo;ll get back to you, eventually.
            </p>
            <span class="card-cta"><span class="card-rule"></span>Contact Ops</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Latest notes -->
    {notes.length > 0 && (
      <section class="band">
        <div class="band-inner">
          <div class="band-head reveal-up">
            <span class="kicker">Latest</span>
            <h2>From the notes</h2>
          </div>
          <div class="note-grid">
            {notes.map((note) => (
              <a href={`/notes/${note.id}`} class="note-card reveal-up">
                <span class="note-date">{fmtDate(note.data.date)}</span>
                <h3>{note.data.title}</h3>
                {note.data.description && <p>{note.data.description}</p>}
                <span class="note-read">Read <span class="arrow">→</span></span>
              </a>
            ))}
          </div>
          <div class="band-foot reveal-up">
            <a href="/notes" class="chip chip-a">
              <span class="dot"></span>
              <span class="chip-label">All Notes</span>
              <span class="chip-note">→</span>
            </a>
          </div>
        </div>
      </section>
    )}
  </main>
</Base>

<script>
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches

  // ————— cycling tagline —————
  const TAGLINES = [
    'Don’t give up on your dreams',
    'Keep sleeping',
    'Many projects',
    'Quiet operations',
    'Agent fleets',
    'Memory systems',
    'Replies: eventual',
  ]
  const tagEl = document.getElementById('hero-tagline')
  if (tagEl && !reduced) {
    let ti = 0
    setInterval(() => {
      if (document.hidden) return
      tagEl.style.opacity = '0'
      tagEl.style.transform = 'translateY(8px)'
      setTimeout(() => {
        ti = (ti + 1) % TAGLINES.length
        tagEl.textContent = TAGLINES[ti]
        tagEl.style.opacity = '1'
        tagEl.style.transform = 'translateY(0)'
      }, 400)
    }, 2800)
  }

  // ————— cursor glow (idles when converged, pauses when hidden) —————
  const glow = document.getElementById('cursor-glow')
  if (glow && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    let mx = -500, my = -500, gx = -500, gy = -500
    let glowRaf = 0
    const follow = () => {
      const dx = mx - gx
      const dy = my - gy
      if (Math.abs(dx) < 0.1 && Math.abs(dy) < 0.1) {
        glowRaf = 0
        return
      }
      gx += dx * 0.08
      gy += dy * 0.08
      glow.style.transform = `translate(${gx}px, ${gy}px)`
      glowRaf = requestAnimationFrame(follow)
    }
    document.addEventListener('mousemove', (e) => {
      mx = e.clientX
      my = e.clientY
      glow.classList.add('active')
      if (!glowRaf && !document.hidden) glowRaf = requestAnimationFrame(follow)
    }, { passive: true })
    document.addEventListener('mouseleave', () => glow.classList.remove('active'), { passive: true })
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && glowRaf) {
        cancelAnimationFrame(glowRaf)
        glowRaf = 0
      }
    })
  }

  // ————— memory-graph constellation —————
  const canvas = document.getElementById('graph-canvas') as HTMLCanvasElement | null
  if (canvas && !reduced) {
    const ctx = canvas.getContext('2d')
    if (ctx) {
      const COUNT = window.innerWidth < 768 ? 28 : 70
      const LINK = 130
      const LINK2 = LINK * LINK
      const MOUSE_R = 190
      const DPR = Math.min(window.devicePixelRatio || 1, 2)
      let W = 0
      let H = 0
      const mouse = { x: -9999, y: -9999 }
      let raf = 0

      const resize = () => {
        W = window.innerWidth
        H = window.innerHeight
        canvas.width = W * DPR
        canvas.height = H * DPR
        ctx.setTransform(DPR, 0, 0, DPR, 0, 0)
      }
      resize()
      window.addEventListener('resize', resize, { passive: true })

      // palette cached; refreshed only when the theme attribute changes
      let nodeRGB = '167, 139, 250'
      let linkRGB = '241, 238, 247'
      let nodeAlpha = 0.9
      let linkAlpha = 0.16
      const readPalette = () => {
        const styles = getComputedStyle(document.documentElement)
        nodeRGB = styles.getPropertyValue('--graph-node').trim() || nodeRGB
        linkRGB = styles.getPropertyValue('--graph-link').trim() || linkRGB
        const dark = document.documentElement.getAttribute('data-theme') !== 'light'
        nodeAlpha = dark ? 0.9 : 0.65
        linkAlpha = dark ? 0.16 : 0.13
      }
      readPalette()
      new MutationObserver(readPalette).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme'],
      })

      type Node = { x: number; y: number; tx: number; ty: number; vx: number; vy: number; r: number; ph: number }
      const nodes: Node[] = []
      for (let i = 0; i < COUNT; i++) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          tx: Math.random() * W,
          ty: Math.random() * H,
          vx: 0,
          vy: 0,
          r: 1.1 + Math.random() * 2.2,
          ph: Math.random() * Math.PI * 2,
        })
      }

      window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY }, { passive: true })
      window.addEventListener('mouseout', () => { mouse.x = -9999; mouse.y = -9999 }, { passive: true })

      // half-rate when the hero is out of view (battery), full rate when it's the show
      let heroVisible = true
      const hero = document.querySelector('.hero')
      if (hero) {
        new IntersectionObserver((entries) => {
          heroVisible = entries[0]?.isIntersecting ?? true
        }).observe(hero)
      }
      let frameFlip = false

      const frame = () => {
        raf = requestAnimationFrame(frame)
        frameFlip = !frameFlip
        if (!heroVisible && frameFlip) return

        const t = performance.now() / 1000
        ctx.clearRect(0, 0, W, H)

        for (const n of nodes) {
          // drift toward a wandering target; retarget when close
          const dx = n.tx - n.x
          const dy = n.ty - n.y
          const dist = Math.hypot(dx, dy)
          if (dist < 50) {
            n.tx = Math.random() * W
            n.ty = Math.random() * H
          }
          n.vx += (dx / (dist || 1)) * 0.0016
          n.vy += (dy / (dist || 1)) * 0.0016
          n.vx += Math.sin(t * 0.15 + n.ph) * 0.00015
          n.vy += Math.cos(t * 0.15 + n.ph * 1.3) * 0.00015

          // gentle pull toward the cursor
          const mdx = mouse.x - n.x
          const mdy = mouse.y - n.y
          const mdist = Math.hypot(mdx, mdy)
          if (mdist < MOUSE_R && mdist > 1) {
            const pull = (1 - mdist / MOUSE_R) * 0.012
            n.vx += (mdx / mdist) * pull
            n.vy += (mdy / mdist) * pull
          }

          n.vx *= 0.996
          n.vy *= 0.996
          n.x += n.vx
          n.y += n.vy
          if (n.x < -80) n.vx += 0.015
          if (n.x > W + 80) n.vx -= 0.015
          if (n.y < -80) n.vy += 0.015
          if (n.y > H + 80) n.vy -= 0.015
        }

        // edges between nearby nodes (squared-distance early out)
        ctx.lineWidth = 1
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i]
            const b = nodes[j]
            const ex = a.x - b.x
            const ey = a.y - b.y
            const d2 = ex * ex + ey * ey
            if (d2 < LINK2) {
              const d = Math.sqrt(d2)
              ctx.strokeStyle = `rgba(${linkRGB}, ${(1 - d / LINK) * linkAlpha})`
              ctx.beginPath()
              ctx.moveTo(a.x, a.y)
              ctx.lineTo(b.x, b.y)
              ctx.stroke()
            }
          }
        }

        // edges from cursor to nearby nodes
        for (const n of nodes) {
          const d = Math.hypot(n.x - mouse.x, n.y - mouse.y)
          if (d < MOUSE_R) {
            ctx.strokeStyle = `rgba(${nodeRGB}, ${(1 - d / MOUSE_R) * 0.35})`
            ctx.beginPath()
            ctx.moveTo(mouse.x, mouse.y)
            ctx.lineTo(n.x, n.y)
            ctx.stroke()
          }
        }

        // nodes, with a slow shimmer
        for (const n of nodes) {
          const pulse = 0.75 + 0.25 * Math.sin(t * 0.8 + n.ph)
          ctx.fillStyle = `rgba(${nodeRGB}, ${nodeAlpha * pulse})`
          ctx.beginPath()
          ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2)
          ctx.fill()
        }
      }
      raf = requestAnimationFrame(frame)

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          cancelAnimationFrame(raf)
        } else {
          raf = requestAnimationFrame(frame)
        }
      })
    }
  }

  // ————— reveal on scroll —————
  const revealed = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed')
          revealed.unobserve(e.target)
        }
      })
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  )
  document.querySelectorAll('.reveal-up').forEach((el) => revealed.observe(el))
</script>

<style>
  /* ——— background layers ——— */
  #graph-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100vw;
    height: 100vh;
    height: 100dvh;
    pointer-events: none;
    opacity: 0.8;
  }
  #cursor-glow {
    position: fixed;
    top: -300px;
    left: -300px;
    width: 600px;
    height: 600px;
    z-index: 0;
    pointer-events: none;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.07) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  #cursor-glow.active {
    opacity: 1;
  }

  /* ——— hero ——— */
  .hero {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7rem 1.5rem 5rem;
  }
  .hero-inner {
    max-width: 87.5rem;
    width: 100%;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 1.75rem;
  }
  .tagline-slot {
    margin-bottom: 2.25rem;
    min-height: 1.2em;
  }
  #hero-tagline {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent-text);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .name {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(3.5rem, 14vw, 8.5rem);
    line-height: 0.9;
    letter-spacing: -0.045em;
    color: var(--ink);
    text-wrap: balance;
  }
  .name-line {
    display: block;
  }
  .name-grad {
    background: linear-gradient(120deg, var(--ink) 0%, var(--accent-text) 45%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .description {
    margin: 2.25rem auto 0;
    max-width: 480px;
    font-size: 14.5px;
    line-height: 1.8;
    color: var(--dim);
    text-wrap: pretty;
  }

  .chips {
    margin-top: 3.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .chips {
      flex-direction: row;
      gap: 1.75rem;
    }
  }
  .amp {
    display: none;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
  }
  @media (min-width: 768px) {
    .amp {
      display: block;
    }
  }
  .chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    padding: 1rem 2rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--ink);
    transition: border-color 0.4s ease, background 0.4s ease, transform 0.2s ease;
  }
  @media (max-width: 767px) {
    .chips .chip {
      width: min(100%, 300px);
    }
  }
  .chip .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }
  .chip-b .dot {
    background: var(--accent-text);
  }
  .chip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .chip-note {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--faint);
    transition: color 0.3s ease;
  }
  .chip:hover {
    color: var(--ink);
    border-color: var(--accent);
    background: rgba(139, 92, 246, 0.06);
    transform: translateY(-1px);
  }
  .chip:hover .chip-note {
    color: var(--accent-text);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
  }
  @media (max-height: 700px) {
    .scroll-hint {
      display: none;
    }
  }
  .scroll-hint span {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .scroll-track {
    width: 1px;
    height: 2.5rem;
    background: var(--hairline);
    position: relative;
    overflow: hidden;
  }
  .scroll-thumb {
    width: 100%;
    height: 1rem;
    background: var(--dim);
    position: absolute;
    animation: scroll-line 2.2s ease-in-out infinite;
  }
  @keyframes scroll-line {
    0% {
      top: -1rem;
    }
    100% {
      top: 2.5rem;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-thumb {
      animation: none;
      top: 0.75rem;
    }
  }

  /* ——— bands (sections) ——— */
  .band {
    position: relative;
    z-index: 10;
    padding: 6rem 1.5rem;
  }
  .band-inner {
    max-width: 87.5rem;
    margin: 0 auto;
  }
  .band-head {
    margin-bottom: 4rem;
  }
  .kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 1rem;
  }
  .band h2 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.25rem, 6vw, 4.5rem);
    letter-spacing: -0.04em;
    line-height: 1.05;
    color: var(--ink);
    text-wrap: balance;
  }
  .uword {
    position: relative;
    display: inline-block;
  }
  .uword::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 2px;
  }
  .u1::after {
    background: linear-gradient(90deg, var(--accent), var(--accent-text));
  }
  .u2::after {
    background: linear-gradient(90deg, var(--accent-text), var(--accent));
  }

  .cards {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .cards {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }
  .card {
    display: block;
    border: 1px solid var(--hairline);
    padding: 3rem 2.5rem;
    color: var(--ink);
    position: relative;
    overflow: hidden;
    transition: border-color 0.5s ease;
  }
  @media (min-width: 1024px) {
    .card {
      padding: 4rem 3.5rem;
    }
  }
  .card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  .card:hover {
    color: var(--ink);
    border-color: rgba(139, 92, 246, 0.55);
  }
  .card:hover::before {
    opacity: 1;
  }
  .card-kicker {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--accent-text);
    margin-bottom: 1.4rem;
  }
  .card h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: -0.03em;
    margin-bottom: 1.1rem;
  }
  .card p {
    color: var(--dim);
    font-size: 15.5px;
    line-height: 1.75;
    max-width: 28rem;
    margin-bottom: 2.25rem;
    text-wrap: pretty;
  }
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    transition: color 0.3s ease;
  }
  .card-rule {
    display: inline-block;
    width: 3rem;
    height: 1px;
    background: var(--hairline);
    transition: width 0.5s ease, background 0.5s ease;
  }
  .card:hover .card-cta {
    color: var(--accent-text);
  }
  .card:hover .card-rule {
    width: 5rem;
    background: var(--accent);
  }

  /* ——— latest notes ——— */
  .note-grid {
    display: grid;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .note-grid {
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }
  }
  .note-card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--hairline);
    padding: 2.25rem 2rem;
    color: var(--ink);
    transition: border-color 0.5s ease;
  }
  .note-card:hover {
    color: var(--ink);
    border-color: rgba(139, 92, 246, 0.55);
  }
  .note-date {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--faint);
    margin-bottom: 1.1rem;
  }
  .note-card h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.3rem;
    letter-spacing: -0.02em;
    line-height: 1.3;
    margin-bottom: 0.8rem;
  }
  .note-card p {
    color: var(--dim);
    font-size: 14px;
    line-height: 1.7;
    margin-bottom: 1.75rem;
    text-wrap: pretty;
  }
  .note-read {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    transition: color 0.3s ease;
  }
  .note-read .arrow {
    transition: transform 0.3s ease;
  }
  .note-card:hover .note-read {
    color: var(--accent-text);
  }
