---
import { getCollection } from 'astro:content'
import Base from '../layouts/Base.astro'
import Footer from '../components/Footer.astro'
import Mark from '../components/Mark.astro'

const NAV_LINKS = [
  { label: 'HOME', href: '/' },
  { label: 'BLOG', href: '/notes' },
  { label: 'PROJECTS', href: '#' },
  { label: 'ABOUT', href: '#' },
  { label: 'CONTACT', href: 'https://opnform.remotelyhuman.com/forms/contact-ops-tavcjx' },
]

const notes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3)

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
---

<Base title="Remotely Human">
  <script is:inline>
    // Legacy Carrd hash-section URLs → real pages (OAuth verification links, old bookmarks)
    const map = {
      '#privacy-policy-section': '/privacy',
      '#privacy-policy': '/privacy',
      '#privacy': '/privacy',
      '#terms-of-service-section': '/terms',
      '#terms-of-service': '/terms',
      '#terms': '/terms',
    }
    const target = map[location.hash.toLowerCase()]
    if (target) location.replace(target)
  </script>

  <!-- Memory-graph constellation background -->
  <canvas id="graph-canvas" aria-hidden="true"></canvas>
  <div id="cursor-glow" aria-hidden="true"></div>

  <!-- Navigation -->
  <header>
    <nav class="topnav">
      <a href="/" class="logo"><Mark size={20} /> <span>REMOTELY HUMAN</span></a>
      <div class="nav-right">
        <ul class="desktop-menu">
          {NAV_LINKS.map((link) => (
            <li>
              <a href={link.href} class={link.href === '/' ? 'active' : ''}>{link.label}</a>
            </li>
          ))}
        </ul>
        <button id="theme-toggle" class="icon-btn" aria-label="Toggle light/dark theme">
          <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4.5"/><line x1="12" y1="2" x2="12" y2="4.5"/><line x1="12" y1="19.5" x2="12" y2="22"/><line x1="2" y1="12" x2="4.5" y2="12"/><line x1="19.5" y1="12" x2="22" y2="12"/><line x1="4.8" y1="4.8" x2="6.6" y2="6.6"/><line x1="17.4" y1="17.4" x2="19.2" y2="19.2"/><line x1="4.8" y1="19.2" x2="6.6" y2="17.4"/><line x1="17.4" y1="6.6" x2="19.2" y2="4.8"/></svg>
          <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
        <button id="menu-open" class="icon-btn menu-btn" aria-label="Open menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="4" y1="7" x2="20" y2="7"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/></svg>
        </button>
      </div>
    </nav>
    <div id="mobile-overlay" class="mobile-overlay" role="dialog" aria-modal="true" aria-label="Navigation menu">
      <div class="mobile-top">
        <a href="/" class="logo"><Mark size={20} /> <span>REMOTELY HUMAN</span></a>
        <button id="menu-close" class="icon-btn" aria-label="Close menu">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
        </button>
      </div>
      <ul>
        {NAV_LINKS.map((link) => <li><a href={link.href}>{link.label}</a></li>)}
      </ul>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <p class="eyebrow">The Official Home of Remotely Human</p>

      <p class="tagline-slot"><span id="hero-tagline">Don&rsquo;t give up on your dreams</span></p>

      <h1 class="name-line">Remotely</h1>
      <h1 class="name-line name-grad">Human</h1>

      <p class="description">
        We work quietly across many projects. If you received an email from
        @remotelyhuman.com, you&rsquo;re in the right place.
      </p>

      <div class="chips">
        <a href="/notes" class="chip chip-a">
          <span class="dot"></span>
          <span class="chip-label">Blog</span>
          <span class="chip-note">// notes &amp; posts</span>
        </a>
        <span class="amp" aria-hidden="true">&amp;</span>
        <a href="https://opnform.remotelyhuman.com/forms/contact-ops-tavcjx" class="chip chip-b">
          <span class="dot"></span>
          <span class="chip-label">Contact Ops</span>
          <span class="chip-note">// replies: eventual</span>
        </a>
      </div>
    </div>

    <div class="scroll-hint" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-track"><div class="scroll-thumb"></div></div>
    </div>
  </section>

  <!-- What we do -->
  <section class="band">
    <div class="band-inner">
      <div class="band-head reveal-up">
        <span class="kicker">What We Do</span>
        <h2><span class="uword u1">Notes</span> &amp; <span class="uword u2">ops</span></h2>
      </div>
      <div class="cards">
        <a href="/notes" class="card reveal-up">
          <span class="card-kicker">Writing</span>
          <h3>The garden</h3>
          <p>
            A garden, not a blog. Notes land here when a conversation or a build
            produces something worth keeping — no theme, no schedule.
          </p>
          <span class="card-cta"><span class="card-rule"></span>Read Notes</span>
        </a>
        <a href="https://opnform.remotelyhuman.com/forms/contact-ops-tavcjx" class="card reveal-up">
          <span class="card-kicker">Operations</span>
          <h3>The ops desk</h3>
          <p>
            Status: dreaming. Keep sleeping. The desk reads everything that
            comes through — say hello and we&rsquo;ll get back to you, eventually.
          </p>
          <span class="card-cta"><span class="card-rule"></span>Contact Ops</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Latest notes -->
  {notes.length > 0 && (
    <section class="band">
      <div class="band-inner">
        <div class="band-head reveal-up">
          <span class="kicker">Latest</span>
          <h2>From the notes</h2>
        </div>
        <div class="note-grid">
          {notes.map((note) => (
            <a href={`/notes/${note.id}`} class="note-card reveal-up">
              <span class="note-date">{fmtDate(note.data.date)}</span>
              <h3>{note.data.title}</h3>
              {note.data.description && <p>{note.data.description}</p>}
              <span class="note-read">Read <span class="arrow">→</span></span>
            </a>
          ))}
        </div>
        <div class="band-foot reveal-up">
          <a href="/notes" class="chip chip-a">
            <span class="dot"></span>
            <span class="chip-label">All Notes</span>
            <span class="chip-note">→</span>
          </a>
        </div>
      </div>
    </section>
  )}

  <Footer />
</Base>

<script>
  // ————— theme toggle —————
  const root = document.documentElement
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const next = root.getAttribute('data-theme') === 'light' ? 'dark' : 'light'
    root.setAttribute('data-theme', next)
    localStorage.setItem('rh-theme', next)
  })

  // ————— nav background on scroll —————
  const hdr = document.querySelector('header')
  window.addEventListener('scroll', () => {
    hdr?.classList.toggle('scrolled', window.scrollY > 40)
  }, { passive: true })

  // ————— mobile menu —————
  const overlay = document.getElementById('mobile-overlay')
  document.getElementById('menu-open')?.addEventListener('click', () => overlay?.classList.add('open'))
  document.getElementById('menu-close')?.addEventListener('click', () => overlay?.classList.remove('open'))
  overlay?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => overlay.classList.remove('open')))

  // ————— cycling tagline —————
  const TAGLINES = [
    'Don’t give up on your dreams',
    'Keep sleeping',
    'Many projects',
    'Quiet operations',
    'Agent fleets',
    'Memory systems',
    'Replies: eventual',
  ]
  const tagEl = document.getElementById('hero-tagline')
  if (tagEl) {
    let ti = 0
    setInterval(() => {
      tagEl.style.opacity = '0'
      tagEl.style.transform = 'translateY(8px)'
      setTimeout(() => {
        ti = (ti + 1) % TAGLINES.length
        tagEl.textContent = TAGLINES[ti]
        tagEl.style.opacity = '1'
        tagEl.style.transform = 'translateY(0)'
      }, 400)
    }, 2800)
  }

  // ————— cursor glow —————
  const glow = document.getElementById('cursor-glow')
  if (glow && window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
    let mx = -500, my = -500, gx = -500, gy = -500
    const follow = () => {
      gx += (mx - gx) * 0.08
      gy += (my - gy) * 0.08
      glow.style.transform = `translate(${gx}px, ${gy}px)`
      requestAnimationFrame(follow)
    }
    document.addEventListener('mousemove', (e) => {
      mx = e.clientX
      my = e.clientY
      glow.classList.add('active')
    }, { passive: true })
    document.addEventListener('mouseleave', () => glow.classList.remove('active'), { passive: true })
    follow()
  }

  // ————— memory-graph constellation —————
  const canvas = document.getElementById('graph-canvas') as HTMLCanvasElement | null
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches
  if (canvas && !reduced) {
    const ctx = canvas.getContext('2d')
    if (ctx) {
      const COUNT = window.innerWidth < 768 ? 28 : 70
      const LINK = 130
      const MOUSE_R = 190
      let W = 0
      let H = 0
      const mouse = { x: -9999, y: -9999 }
      let raf = 0

      type Node = { x: number; y: number; tx: number; ty: number; vx: number; vy: number; r: number; ph: number }
      const nodes: Node[] = []

      const resize = () => {
        W = canvas.width = window.innerWidth
        H = canvas.height = window.innerHeight
      }
      resize()
      window.addEventListener('resize', resize, { passive: true })

      for (let i = 0; i < COUNT; i++) {
        nodes.push({
          x: Math.random() * W,
          y: Math.random() * H,
          tx: Math.random() * W,
          ty: Math.random() * H,
          vx: 0,
          vy: 0,
          r: 1.1 + Math.random() * 2.2,
          ph: Math.random() * Math.PI * 2,
        })
      }

      window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY }, { passive: true })
      window.addEventListener('mouseout', () => { mouse.x = -9999; mouse.y = -9999 }, { passive: true })

      const frame = () => {
        const t = performance.now() / 1000
        ctx.clearRect(0, 0, W, H)
        const styles = getComputedStyle(document.documentElement)
        const nodeRGB = styles.getPropertyValue('--graph-node').trim() || '167, 139, 250'
        const linkRGB = styles.getPropertyValue('--graph-link').trim() || '241, 238, 247'
        const dark = document.documentElement.getAttribute('data-theme') !== 'light'
        const nodeAlpha = dark ? 0.9 : 0.65
        const linkAlpha = dark ? 0.16 : 0.13

        for (const n of nodes) {
          // drift toward a wandering target; retarget when close
          const dx = n.tx - n.x
          const dy = n.ty - n.y
          const dist = Math.hypot(dx, dy)
          if (dist < 50) {
            n.tx = Math.random() * W
            n.ty = Math.random() * H
          }
          n.vx += (dx / (dist || 1)) * 0.0016
          n.vy += (dy / (dist || 1)) * 0.0016
          n.vx += Math.sin(t * 0.15 + n.ph) * 0.00015
          n.vy += Math.cos(t * 0.15 + n.ph * 1.3) * 0.00015

          // gentle pull toward the cursor
          const mdx = mouse.x - n.x
          const mdy = mouse.y - n.y
          const mdist = Math.hypot(mdx, mdy)
          if (mdist < MOUSE_R && mdist > 1) {
            const pull = (1 - mdist / MOUSE_R) * 0.012
            n.vx += (mdx / mdist) * pull
            n.vy += (mdy / mdist) * pull
          }

          n.vx *= 0.996
          n.vy *= 0.996
          n.x += n.vx
          n.y += n.vy
          if (n.x < -80) n.vx += 0.015
          if (n.x > W + 80) n.vx -= 0.015
          if (n.y < -80) n.vy += 0.015
          if (n.y > H + 80) n.vy -= 0.015
        }

        // edges between nearby nodes
        ctx.lineWidth = 1
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const a = nodes[i]
            const b = nodes[j]
            const d = Math.hypot(a.x - b.x, a.y - b.y)
            if (d < LINK) {
              ctx.strokeStyle = `rgba(${linkRGB}, ${(1 - d / LINK) * linkAlpha})`
              ctx.beginPath()
              ctx.moveTo(a.x, a.y)
              ctx.lineTo(b.x, b.y)
              ctx.stroke()
            }
          }
        }

        // edges from cursor to nearby nodes
        for (const n of nodes) {
          const d = Math.hypot(n.x - mouse.x, n.y - mouse.y)
          if (d < MOUSE_R) {
            ctx.strokeStyle = `rgba(${nodeRGB}, ${(1 - d / MOUSE_R) * 0.35})`
            ctx.beginPath()
            ctx.moveTo(mouse.x, mouse.y)
            ctx.lineTo(n.x, n.y)
            ctx.stroke()
          }
        }

        // nodes, with a slow shimmer
        for (const n of nodes) {
          const pulse = 0.75 + 0.25 * Math.sin(t * 0.8 + n.ph)
          ctx.fillStyle = `rgba(${nodeRGB}, ${nodeAlpha * pulse})`
          ctx.beginPath()
          ctx.arc(n.x, n.y, n.r, 0, Math.PI * 2)
          ctx.fill()
        }

        raf = requestAnimationFrame(frame)
      }
      raf = requestAnimationFrame(frame)

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          cancelAnimationFrame(raf)
        } else {
          raf = requestAnimationFrame(frame)
        }
      })
    }
  }

  // ————— reveal on scroll —————
  const revealed = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('revealed')
          revealed.unobserve(e.target)
        }
      })
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  )
  document.querySelectorAll('.reveal-up').forEach((el) => revealed.observe(el))
</script>

<style>
  /* ——— background layers ——— */
  #graph-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.8;
  }
  #cursor-glow {
    position: fixed;
    top: -300px;
    left: -300px;
    width: 600px;
    height: 600px;
    z-index: 0;
    pointer-events: none;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.07) 0%, transparent 65%);
    opacity: 0;
    transition: opacity 0.5s ease;
  }
  #cursor-glow.active {
    opacity: 1;
  }

  /* ——— navigation ——— */
  header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 40;
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }
  header.scrolled {
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom-color: var(--hairline);
  }
  .topnav {
    max-width: 87.5rem;
    margin: 0 auto;
    height: 4.5rem;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    color: var(--ink);
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.2em;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    opacity: 0.85;
    transition: opacity 0.3s ease;
  }
  .logo:hover {
    color: var(--ink);
    opacity: 1;
  }
  .logo :global(svg) {
    color: var(--accent);
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }
  .desktop-menu {
    display: none;
    list-style: none;
    gap: 2rem;
  }
  .desktop-menu a {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--dim);
    position: relative;
    transition: color 0.3s ease;
  }
  .desktop-menu a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 1px;
    width: 0;
    background: var(--ink);
    transition: width 0.3s ease;
  }
  .desktop-menu a:hover {
    color: var(--ink);
  }
  .desktop-menu a:hover::after {
    width: 100%;
  }
  .desktop-menu a.active {
    color: var(--accent-text);
  }
  .desktop-menu a.active::after {
    width: 100%;
    background: var(--accent);
  }
  .icon-btn {
    background: none;
    border: none;
    color: var(--dim);
    cursor: pointer;
    display: flex;
    padding: 0.3rem;
    transition: color 0.3s ease;
  }
  .icon-btn:hover {
    color: var(--ink);
  }
  :global([data-theme='dark']) .icon-moon {
    display: none;
  }
  :global([data-theme='light']) .icon-sun {
    display: none;
  }
  .menu-btn {
    display: flex;
  }
  @media (min-width: 768px) {
    .desktop-menu {
      display: flex;
    }
    .menu-btn {
      display: none;
    }
  }

  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: var(--bg);
    display: flex;
    flex-direction: column;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }
  .mobile-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }
  .mobile-top {
    height: 4.5rem;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mobile-overlay ul {
    list-style: none;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.2rem;
  }
  .mobile-overlay ul a {
    font-family: var(--font-display);
    font-size: 2.6rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .mobile-overlay ul a:hover {
    color: var(--accent-text);
  }

  /* ——— hero ——— */
  .hero {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7rem 1.5rem 5rem;
  }
  .hero-inner {
    max-width: 87.5rem;
    width: 100%;
    text-align: center;
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 1.75rem;
  }
  .tagline-slot {
    margin-bottom: 2.25rem;
    min-height: 1.2em;
  }
  #hero-tagline {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent-text);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .name-line {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(3.5rem, 14vw, 8.5rem);
    line-height: 0.9;
    letter-spacing: -0.045em;
    color: var(--ink);
  }
  .name-grad {
    background: linear-gradient(120deg, var(--ink) 0%, var(--accent-text) 45%, var(--accent) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .description {
    margin: 2.25rem auto 0;
    max-width: 480px;
    font-size: 14.5px;
    line-height: 1.8;
    color: var(--dim);
  }

  .chips {
    margin-top: 3.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  @media (min-width: 768px) {
    .chips {
      flex-direction: row;
      gap: 1.75rem;
    }
  }
  .amp {
    display: none;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--faint);
  }
  @media (min-width: 768px) {
    .amp {
      display: block;
    }
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1rem 2rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    color: var(--ink);
    transition: border-color 0.4s ease, background 0.4s ease, transform 0.2s ease;
  }
  .chip .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }
  .chip-b .dot {
    background: var(--accent-text);
  }
  .chip-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
  .chip-note {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--faint);
    transition: color 0.3s ease;
  }
  .chip:hover {
    color: var(--ink);
    border-color: var(--accent);
    background: rgba(139, 92, 246, 0.06);
    transform: translateY(-1px);
  }
  .chip:hover .chip-note {
    color: var(--accent-text);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.25rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.7rem;
  }
  .scroll-hint span {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .scroll-track {
    width: 1px;
    height: 2.5rem;
    background: var(--hairline);
    position: relative;
    overflow: hidden;
  }
